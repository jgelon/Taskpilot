# Full URL of the app — used for OIDC redirect and CORS
# e.g. https://tasks.your-domain.com
APP_URL=https://your-app-domain.com

# Hostname only — used by Traefik routing rule (no https://, no trailing slash)
# e.g. tasks.your-domain.com
APP_DOMAIN=your-app-domain.com

# Authentik public URL — used by the browser for login, and by the backend
# for issuer validation in tokens. No trailing slash.
# e.g. https://auth.your-domain.com
AUTHENTIK_URL=https://auth.your-domain.com

# Authentik internal URL — used by the backend to fetch JWKS keys directly
# without going through Traefik. Uses the container name and internal port.
# Default is http://authentik-server:9000 if not set.
AUTHENTIK_INTERNAL_URL=http://authentik-server:9000

# Authentik group name that grants admin access (Settings, categories, import/export)
# Default: taskpilot-admin
ADMIN_GROUP=taskpilot-admin

# OIDC Client ID from your Authentik application
# Found in Authentik → Applications → Your App → Provider → Client ID
OIDC_CLIENT_ID=your-client-id-here

# ── Gamification feature flags (default: true) ────────────────────────────────
# Points are always calculated, but hidden when FEATURE_POINTS=false
# Set any to 'false' to disable that feature in the UI
FEATURE_POINTS=true
FEATURE_STREAKS=true
FEATURE_ACHIEVEMENTS=true
FEATURE_LEADERBOARD=true

# ── Push notifications (Web Push / VAPID) ────────────────────────────────────
# Generate your own VAPID keys (run once):
#   node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(JSON.stringify(k))"
# Or use: https://vapidkeys.com
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:you@your-domain.com

# ── Feature flags (new) ───────────────────────────────────────────────────────
FEATURE_ASSIGNMENT=true
FEATURE_PUSH_NOTIFICATIONS=true
FEATURE_TODOIST=true
